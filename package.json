{
  "name": "paritosh-cold",
  "version": "1.0.0",
  "description": "Paritosh Cold — cold storage accounting (Electron + React + SQLite)",
  "main": "./out/main/index.js",
  "author": "Paritosh Cold",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "electron-vite build && electron-builder --publish never",
    "app:mac": "electron-vite build && electron-builder --mac dir && rm -rf '/Applications/Paritosh Cold.app' && cp -R 'release/mac-arm64/Paritosh Cold.app' /Applications/ && xattr -cr '/Applications/Paritosh Cold.app' && rm -rf 'release/mac-arm64' && echo '\\n✅ Updated /Applications/Paritosh Cold.app'"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "antd": "^5.21.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.4.3",
    "drizzle-orm": "^0.36.0",
    "i18next": "^23.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "drizzle-kit": "^0.28.0",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.3"
  }
}
